# ── Required: at least one LLM provider key ─────────────────────────────────

# Recommended: OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini

# Or: custom OpenAI-compatible endpoint (Ollama, vLLM, llama.cpp, LM Studio,
# Factory AI, any self-hosted server). On Railway, the URL must be publicly
# reachable — use Cloudflare Tunnel / ngrok / Tailscale Funnel to expose a
# local model. localhost / 127.0.0.1 / 0.0.0.0 will NOT work.
# OPENAI_API_KEY=ollama                       # any string your server accepts
# OPENAI_BASE_URL=https://<tunnel>.trycloudflare.com/v1
# LLM_MODEL=gemma4                             # model ID per GET /v1/models

# Or: direct Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# ── Optional: Tool APIs ──────────────────────────────────────────────────────

# Web search (pick one or more)
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# ── Optional: Browser automation ─────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Gateway security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Terminal backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60
